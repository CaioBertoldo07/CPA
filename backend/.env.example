DATABASE_NAME=cpa
DATABASE_USER=postgres
DATABASE_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DATABASE_HOST=db-cpa
DATABASE_PORT=5432
DATABASE_URL="postgresql://postgres:REPLACE_WITH_STRONG_DB_PASSWORD@db-cpa:5432/cpa?schema=public"

JWT_SECRET=REPLACE_WITH_MIN_32_CHAR_RANDOM_SECRET
PORT=3034
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ENABLE_SWAGGER=true
# Opcional: sobrescreve a URL exibida em "servers" no Swagger.
# Exemplo produção: https://api.seudominio.com
SWAGGER_SERVER_URL=

# Definir como 'true' para importar cursos do Lyceum automaticamente ao iniciar o servidor
IMPORT_CURSOS_ON_START=false

# Definir como 'true' para desabilitar validação de certificado SSL (apenas em desenvolvimento)
DISABLE_SSL_VALIDATION=false

# Segredo para geração de HMAC-SHA256 da matrícula (pepper). Use um valor aleatório forte (mínimo 32 caracteres) em produção.
MATRICULA_HASH_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Lyceum consumer tem que ser um usuario com permissoes de consumo da api da uea 
LYCEUM_CONSUMER_EMAIL=your-email@example.com
LYCEUM_CONSUMER_PASSWORD=your-password

ADMIN_NAME=Caio
ADMIN_EMAIL=cbb.eng22@uea.edu.br
